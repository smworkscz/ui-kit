{
  "name": "@smworks-cz/ui-kit",
  "version": "1.5.1",
  "description": "SMWORKS UI KIT — component library for SMWORKS apps",
  "author": "Daniel Cvejn <cvejn@smworks.cz>",
  "license": "MIT",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://ui.smworks.cz",
  "repository": {
    "type": "git",
    "url": "https://github.com/smworkscz/ui-kit"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "dev:link": "tsup --watch --onSuccess \"yalc push\"",
    "preview": "vite --config preview/vite.config.ts",
    "build:preview": "node scripts/generate-llm-docs.mjs && vite build --config preview/vite.config.ts && cp preview/dist/index.html preview/dist/404.html",
    "generate:llm-docs": "node scripts/generate-llm-docs.mjs"
  },
  "peerDependencies": {
    "@phosphor-icons/react": ">=2.1.0",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser-playwright": "^4.1.2",
    "@vitest/coverage-v8": "^4.1.2",
    "playwright": "^1.59.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vite": "^8.0.5",
    "vitest": "^4.1.2"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
