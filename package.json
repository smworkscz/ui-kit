{
  "name": "sm-ui",
  "version": "0.1.0",
  "description": "Component library for SMWORKS",
  "author": "Daniel Cvejn <cvejn@smworks.cz>",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "preview": "vite --config preview/vite.config.ts",
    "build:preview": "vite build --config preview/vite.config.ts"
  },
  "peerDependencies": {
    "@phosphor-icons/react": ">=2.1.0",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser-playwright": "^4.1.2",
    "@vitest/coverage-v8": "^4.1.2",
    "playwright": "^1.59.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vite": "^8.0.5",
    "vitest": "^4.1.2"
  }
}