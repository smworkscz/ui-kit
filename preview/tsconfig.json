{
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "isolatedModules": true,
    "paths": {
      "sm-ui": ["../src"],
      "sm-ui/*": ["../src/*"]
    }
  },
  "include": ["src"]
}
